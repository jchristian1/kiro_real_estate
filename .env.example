# =============================================================================
# Environment Variables — copy this file to .env and fill in real values.
# Run `make generate-secrets` to generate cryptographically secure values for
# ENCRYPTION_KEY and SECRET_KEY.
# =============================================================================

# --- Database ---

# SQLite connection string. Use an absolute path in production.
DATABASE_URL=sqlite:///./gmail_lead_sync.db

# --- Secrets (REQUIRED — must be ≥ 32 characters each) ---

# Fernet key used to encrypt Gmail credentials at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-to-a-32-plus-character-fernet-key-value

# Secret used to sign session tokens. Must be ≥ 32 characters.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-32-plus-character-random-secret-value

# --- Server ---

# Host address the API server binds to.
API_HOST=0.0.0.0

# Port the API server listens on.
API_PORT=8000

# Comma-separated list of allowed CORS origins for the frontend.
CORS_ORIGINS=http://localhost:5173

# Set to true to allow cookies/auth headers in cross-origin requests.
CORS_ALLOW_CREDENTIALS=true

# --- Session ---

# How long a user session remains valid, in hours.
SESSION_TIMEOUT_HOURS=24

# --- Watcher / Worker ---

# How often the Gmail IMAP watcher polls for new emails, in seconds.
SYNC_INTERVAL_SECONDS=300

# Maximum time (milliseconds) allowed for a regex pattern to execute before
# it is rejected as potentially catastrophic.
REGEX_TIMEOUT_MS=1000

# Set to true to automatically restart a failed watcher after a 60-second
# cooldown. Set to false to require manual intervention.
ENABLE_AUTO_RESTART=true

# --- Application ---

# Runtime environment. Set to "production" to enable secure cookies and
# stricter security defaults.
ENVIRONMENT=development

# Python log level for the backend. Valid values: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Maximum number of leads returned per paginated API response.
MAX_LEADS_PER_PAGE=50

# Path to the directory containing the compiled frontend static files.
# In Docker this is handled automatically; override only if serving from a
# custom location.
STATIC_FILES_DIR=../frontend/dist
