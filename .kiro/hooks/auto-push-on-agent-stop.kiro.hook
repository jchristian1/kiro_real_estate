{
  "enabled": true,
  "name": "Auto Push to GitHub",
  "description": "Automatically commits and pushes any modified files to GitHub after each agent session ends",
  "version": "1",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "git add -A && git diff --cached --quiet || git commit -m \"auto: agent session changes $(date '+%Y-%m-%d %H:%M')\" && git push origin feature/leads-preapproval"
  }
}